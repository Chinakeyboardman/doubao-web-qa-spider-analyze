# =============================================================================
# 豆包 QA 采集系统 .gitignore — 按目录特性分类
# =============================================================================

# -----------------------------------------------------------------------------
# 配置与密钥（根目录）
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
*.egg-info/
*.egg
dist/
build/
*.whl

# 测试与质量工具
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# -----------------------------------------------------------------------------
# Node.js（douyin-crawler）
# -----------------------------------------------------------------------------
node_modules/

# -----------------------------------------------------------------------------
# 浏览器自动化（integration/.browser_state）
# Playwright 登录态、cookies、调试 dump 的 HTML/PNG
# -----------------------------------------------------------------------------
integration/.browser_state/

# -----------------------------------------------------------------------------
# 导出与输出
# -----------------------------------------------------------------------------
export/
output/
*.log

# -----------------------------------------------------------------------------
# 数据库（Docker 卷）
# -----------------------------------------------------------------------------
pg_data/

# -----------------------------------------------------------------------------
# 系统与编辑器
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE（可选：若需提交团队配置可移除对应行）
.idea/
.vscode/*.log

# -----------------------------------------------------------------------------
# 子项目特定
# -----------------------------------------------------------------------------

# douyin-crawler/worker（uv）
douyin-crawler/worker/.venv/

# Douyin_TikTok_Download_API（若存在独立 venv）
Douyin_TikTok_Download_API/venv/
Douyin_TikTok_Download_API/.venv/
Douyin_TikTok_Download_API/.venv313/
Douyin_TikTok_Download_API/.venv39/
# 本地 config 备份（含 Cookie，勿提交）
Douyin_TikTok_Download_API/**/config.yaml*.backup
Douyin_TikTok_Download_API/download/
Douyin_TikTok_Download_API/app/api/endpoints/download/
Douyin_TikTok_Download_API/Screenshots/

# query-input 导入的 Excel 源文件（含业务数据）
query-input/*.xlsx
query-input/*.xls

# Celery
celerybeat-schedule
celerybeat.pid
*.pid

# -----------------------------------------------------------------------------
# 临时与调试
# -----------------------------------------------------------------------------
*.tmp
*.temp
.cache/
