# ============================================
# 父项目统一配置
# 复制为 .env 后修改实际值
# ============================================

# ---------- 数据库类型 ----------
# postgresql 或 mysql（默认 postgresql）
DB_TYPE=postgresql

# ---------- PostgreSQL（DB_TYPE=postgresql 时使用） ----------
PGHOST=localhost
PGPORT=5432
PGDATABASE=doubao
PGUSER=postgres
PGPASSWORD=postgres

# ---------- MySQL（DB_TYPE=mysql 时使用） ----------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=doubao
MYSQL_USER=root
MYSQL_PASSWORD=

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0

# ---------- 抖音视频下载 API ----------
DOUYIN_DOWNLOAD_API_URL=http://localhost:8081
DOUYIN_DOWNLOAD_API_PORT=8081

# ---------- 爬虫（通用网页等） ----------
# 设为 false 时可访问证书不受信任的站（浏览器里需点「高级」通过的页面）
CRAWLER_VERIFY_SSL=true

# ---------- 火山云 API ----------
VOLCENGINE_API_KEY=
# 可选别名（与 VOLCENGINE_API_KEY 二选一）
ARK_API_KEY=
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_VISION_MODEL=
VOLCENGINE_SEED_MODEL=
# 抖音视频特征抽取专用（未配置则用 SEED_MODEL）
VOLCENGINE_SEEDANCE_MODEL=
DOUYIN_FILE_PROCESS_MAX_WAIT_SECONDS=900
DOUYIN_FILE_PROCESS_POLL_INTERVAL_SECONDS=20
DOUYIN_FILE_PROCESS_MAX_POLL_INTERVAL_SECONDS=60

# ---------- 火山引擎录音文件识别大模型 2.0 (Flash ASR) ----------
# 用于 audio-transcribe：抖音视频 -> 抽 mp3 -> ASR 转写
VOLCENGINE_ASR_APP_ID=
VOLCENGINE_ASR_ACCESS_TOKEN=
VOLCENGINE_ASR_RESOURCE_ID=volc.bigasr.auc_turbo
VOLCENGINE_ASR_ENDPOINT=https://openspeech.bytedance.com/api/v3/auc/bigmodel/recognize/flash
VOLCENGINE_ASR_MODEL_NAME=bigmodel
VOLCENGINE_ASR_TIMEOUT_SECONDS=180

# ---------- SMS API (自动登录) ----------
SMS_API_BASE_URL=https://sms.guangyinai.com
SMS_API_TOKEN=
SMS_DEVICE_ID=doubao-crawler-01
SMS_PLATFORM=doubao

# ---------- 时区 ----------
TZ=Asia/Shanghai
