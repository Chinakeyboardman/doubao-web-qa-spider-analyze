# ============================================
# 父项目统一配置
# 复制为 .env 后修改实际值
# ============================================

# ---------- 数据库类型 ----------
# postgresql 或 mysql（默认 postgresql）
DB_TYPE=postgresql

# ---------- PostgreSQL（DB_TYPE=postgresql 时使用） ----------
PGHOST=localhost
PGPORT=5432
PGDATABASE=doubao
PGUSER=postgres
PGPASSWORD=postgres

# ---------- MySQL（DB_TYPE=mysql 时使用） ----------
# 公司 test 环境（阿里云 RDS）：MYSQL_HOST=rm-wz95j76y1k9c1101lro.mysql.rds.aliyuncs.com
#  MYSQL_DATABASE=doubao_web_qa_spider_analyze（需 DBA 创建并授权）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=doubao
MYSQL_USER=root
MYSQL_PASSWORD=

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0

# ---------- 抖音视频下载 API ----------
DOUYIN_DOWNLOAD_API_URL=http://localhost:8081
DOUYIN_DOWNLOAD_API_PORT=8081
# 大文件下载：流式写入 + 重试（缓解 peer closed connection / 不完整 body）
DOUYIN_DOWNLOAD_MAX_RETRIES=5
DOUYIN_DOWNLOAD_READ_TIMEOUT_SECONDS=900
DOUYIN_DOWNLOAD_CHUNK_BYTES=262144

# ---------- 爬虫（通用网页等） ----------
# 设为 false 时可访问证书不受信任的站（浏览器里需点「高级」通过的页面）
CRAWLER_VERIFY_SSL=true

# ---------- 火山云 API ----------
VOLCENGINE_API_KEY=
# 可选别名（与 VOLCENGINE_API_KEY 二选一）
ARK_API_KEY=
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_VISION_MODEL=
VOLCENGINE_SEED_MODEL=
# 抖音视频特征抽取专用（未配置则用 SEED_MODEL）
VOLCENGINE_SEEDANCE_MODEL=
DOUYIN_FILE_PROCESS_MAX_WAIT_SECONDS=900
DOUYIN_FILE_PROCESS_POLL_INTERVAL_SECONDS=20
DOUYIN_FILE_PROCESS_MAX_POLL_INTERVAL_SECONDS=60

# ---------- 阿里云 OSS ----------
ALIYUN_OSS_ENDPOINT=oss-cn-shenzhen.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY=
ALIYUN_OSS_SECRET_KEY=
ALIYUN_OSS_BUCKET=dev-vedio-file
ALIYUN_OSS_REGION=cn-shenzhen

# ---------- 火山引擎录音文件识别大模型 2.0 (SeedASR) ----------
# 用于 audio-transcribe：抖音视频 -> 抽 mp3 -> 上传 OSS -> ASR 转写
VOLCENGINE_ASR_APP_ID=
VOLCENGINE_ASR_ACCESS_TOKEN=
VOLCENGINE_ASR_RESOURCE_ID=volc.seedasr.auc
VOLCENGINE_ASR_SUBMIT_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/submit
VOLCENGINE_ASR_QUERY_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/query
VOLCENGINE_ASR_TIMEOUT_SECONDS=300

# ---------- 豆包网页采集（参考资料链接）----------
# 回答正文稳定后，再等 N 毫秒再抽「深度思考/参考资料」里的链接（避免 DOM 未渲染完）
DOUBAO_WEB_POST_ANSWER_SETTLE_MS=8000
# 首次抽到的引用数为 0 时，再等待 N 毫秒并重试一轮（0=关闭；调试用）
# DOUBAO_WEB_CITATION_RETRY_MS=12000

# ---------- SMS API (自动登录) ----------
SMS_API_BASE_URL=https://sms.guangyinai.com
SMS_API_TOKEN=
SMS_DEVICE_ID=doubao-crawler-01
SMS_PLATFORM=doubao

# ---------- 时区 ----------
TZ=Asia/Shanghai
